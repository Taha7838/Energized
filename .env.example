# Energized Platform — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to source control.

# ── DockerHub ────────────────────────────────────────────────────────────────
# Your DockerHub account name (e.g. johndoe)
DOCKERHUB_USERNAME=taha7838

# ── Docker Image Tag ─────────────────────────────────────────────────────────
# Set automatically to git SHA in CI. Locally, defaults to "latest" in compose.
IMAGE_TAG=latest

