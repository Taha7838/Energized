# Dockerfile.agent-backend

FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

COPY agent/backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Download the embedding model at build time — same fix as Dockerfile.rag.
# vector_store.py loads SentenceTransformer at module level, which spikes
# memory over 512MB on Render's free tier if it downloads at runtime.
# RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('all-MiniLM-L6-v2')"

COPY agent/backend/ .

# settings.py does a hard sys.exit(1) if .env doesn't exist on disk.
# In production, real values come in as env vars (docker-compose / GitHub Actions).
# This empty file satisfies the existence check without hardcoding any secrets.
RUN touch .env

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]